# Required for Level 2 (LLM email) and Level 3 (agents). Use at least one.
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: provider (openai | anthropic) and model overrides
# LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional: env and logging (development | production, LOG_LEVEL=DEBUG|INFO|WARNING)
# ENV=development
# LOG_LEVEL=INFO
